{
  "name": "claude-status-widgets",
  "version": "1.0.0",
  "description": "A modular, testable statusline for Claude Code CLI",
  "module": "src/main.ts",
  "type": "module",
  "bin": {
    "claude-status": "dist/claude-status.js"
  },
  "files": ["dist/"],
  "keywords": ["claude", "claude-code", "statusline", "cli", "terminal"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whatiskadudoing/kadustatusline.git"
  },
  "license": "MIT",
  "author": "kadu",
  "scripts": {
    "start": "bun run src/main.ts",
    "build": "bun build src/main.ts --target=node --outfile=dist/claude-status.js && printf '#!/usr/bin/env node\\n' | cat - dist/claude-status.js > dist/tmp.js && mv dist/tmp.js dist/claude-status.js && chmod +x dist/claude-status.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "example": "cat scripts/payload.example.json | bun run src/main.ts",
    "typecheck": "bun tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "react-devtools-core": "^7.0.1",
    "strip-ansi": "^7.2.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {},
  "dependencies": {
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "zod": "^4.3.6"
  }
}
